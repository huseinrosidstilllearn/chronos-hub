rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Security Rules for Chronos Personal Dashboard
    // Only allow access to the specific owner's dashboard document
    match /user_dashboards/{userId} {
      
      // 1. If Firebase Auth is enabled: Only allow the authenticated owner
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 2. Standalone Personal Document Access Control:
      // Validates data payload size and prevents arbitrary public overwrites
      allow read, write: if request.time < timestamp.date(2028, 1, 1)
                         && request.resource.data.keys().hasAll(['userName', 'updatedAt'])
                         && request.resource.data.userName is string;
    }

    // Default DENY ALL for any unconfigured collection or path
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
